# En desarrollo, Vite reenvía las peticiones que empiezan por /api al backend DM Virtual.
# Si ves HTTP 502 al validar, el motor no responde en esta URL (arranca uvicorn o ajusta el puerto).
VITE_DEV_PROXY_TARGET=http://localhost:8000

# Opcional: URL absoluta del API (p. ej. otro host o HTTPS). Si está definida, el cliente
# usa esta base en lugar de rutas relativas /api (útil sin proxy o en preview empaquetado).
# Sin barra final.
# VITE_API_BASE=http://localhost:8000
